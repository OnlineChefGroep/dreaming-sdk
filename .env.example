# cursor-dreaming-sdk — development defaults
# Copy to .env and fill in secrets (never commit .env)

# Plugin root override (defaults to ~/.cursor/plugins/local/dreaming)
# DREAM_PLUGIN_ROOT=/path/to/plugin

# Cloud eval runner (weekly-eval.yml)
# CURSOR_API_KEY=

# Dreaming session location (defaults to ~/.cursor/dreaming)
# DREAMING_DIR=

# See python/.env.example for agent-memory env vars
